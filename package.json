{
  "name": "mouse-finder",
  "version": "2.0.0",
  "description": "멀티 모니터 환경에서 마우스/키보드를 화면 위에서 커스텀하는 데스크탑 유틸리티",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "keywords": [
    "mouse",
    "keyboard",
    "overlay",
    "desktop",
    "customization",
    "multi-monitor"
  ],
  "author": "funjo-B",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "koffi": "^2.15.6",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.funjo-b.mouse-finder",
    "productName": "Mouse Finder",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "config.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["ko", "en"],
      "language": 1042
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**",
      "node_modules/koffi/**"
    ]
  }
}
